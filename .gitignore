# yii console commands (regenerated by init)
# /yii  <-- KEEP: needed for Docker migrations
# /yii_test
/yii_test.bat

# phpstorm project files
.idea

# visual studio code project files
.vscode

# netbeans project files
nbproject

# zend studio for eclipse project files
.buildpath
.project
.settings

# windows thumbnail cache
Thumbs.db

# composer vendor dir
/vendor

# composer itself is not needed
composer.phar
# composer.lock is KEPT for reproducible builds

# Mac DS_Store Files
.DS_Store

# node
/node_modules
/package.json
/package-lock.json

# phpunit itself is not needed
phpunit.phar
# local phpunit config
/phpunit.xml

# vagrant runtime
/.vagrant

# Environment files (secrets)
.env
.env.local

# Runtime and generated assets
/backend/runtime/
/frontend/runtime/
/console/runtime/
/backend/web/assets/
/frontend/web/assets/

# Local config files (generated by init — NOT committed)
/common/config/main-local.php
/common/config/params-local.php
/backend/config/main-local.php
/backend/config/params-local.php
/frontend/config/main-local.php
/frontend/config/params-local.php
/console/config/main-local.php
/console/config/params-local.php

# NOTE: backend/web/index.php and frontend/web/index.php are generated by
# `php init` — they ARE committed so Docker build works without running init first
# (The entrypoint.sh runs init at startup, but the index.php stubs need to exist
#  in the image for nginx to serve during init phase)
